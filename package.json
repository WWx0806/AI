{
  "name": "lumin-desktop",
  "version": "1.0.0",
  "description": "Lumin AI 写作桌面端",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "diff": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.lumin.writer",
    "productName": "Lumin",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "ai-service.js",
      "snapshots/**/*",
      "../AI平台/index.html",
      "../AI平台/css/**/*",
      "../AI平台/js/**/*",
      "../AI平台/data/**/*"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "app",
        "filter": [
          "**/*",
          "css/**/*",
          "js/**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
